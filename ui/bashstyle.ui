  <object class="GtkWindow" id="Toolbox">
    <property name="child">
      <object class="GtkGrid" id="toolbox.grid">
        <property name="row-spacing">3</property>
        <child>
          <object class="GtkButton" id="fhostname">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Full Hostname</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">3</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="hostname">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Hostname</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">2</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="username">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Username</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">1</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="time">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Time</property>
