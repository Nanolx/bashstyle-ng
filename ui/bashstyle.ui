<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.1.0 -->
<interface>
  <!-- interface-name bashstyle.ui4 -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkWindow" id="Toolbox">
    <property name="child">
      <object class="GtkGrid" id="toolbox.grid">
        <property name="row-spacing">3</property>
        <child>
          <object class="GtkButton" id="fhostname">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Full Hostname</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">3</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="hostname">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Hostname</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">2</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="username">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Username</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">1</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="time">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Time</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">1</property>
              <property name="row">1</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="fworkdir">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Full Workdir</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">1</property>
              <property name="row">2</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="jobs">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Background Processes</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">1</property>
              <property name="row">3</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="pid">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Bash's Process ID</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">1</property>
              <property name="row">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="date">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Date</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">2</property>
              <property name="row">1</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="sign">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">$ (# if root)</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">3</property>
              <property name="row">1</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="workdir">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Base Workdir</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">2</property>
              <property name="row">2</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="euid">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Effective User ID</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">3</property>
              <property name="row">2</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="bang">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Command Number [History]</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">2</property>
              <property name="row">3</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="number">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Command Number [Session]</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">3</property>
              <property name="row">3</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="shlvl">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Shell Level</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">2</property>
              <property name="row">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="showseconds">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Time since Bash started</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">3</property>
              <property name="row">4</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="toolbox.label.standard">
            <property name="label" translatable="yes">Standard Stuff</property>
            <attributes>
              <attribute name="weight" value="bold"/>
            </attributes>
            <style>
              <class name="rotated_label"/>
            </style>
            <layout>
              <property name="column">0</property>
              <property name="row">0</property>
              <property name="row-span">5</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkSeparator" id="toolbox.separator.1">
            <property name="margin-bottom">5</property>
            <property name="margin-top">5</property>
            <layout>
              <property name="column">0</property>
              <property name="column-span">4</property>
              <property name="row">5</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="showcpuload">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">CPU Load</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">1</property>
              <property name="row">8</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="countprocesses">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Number of Processes</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">1</property>
              <property name="row">7</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="truncpwd">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Trunced Workdir</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">1</property>
              <property name="row">6</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="showsize">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Files Size</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">2</property>
              <property name="row">6</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkDropDown" id="countfiles">
            <property name="model">
              <object class="GtkStringList" id="countfiles.strings">
                <items>
                  <item translatable="yes">Files Amount:</item>
                  <item translatable="yes">Include Hidden Files</item>
                  <item translatable="yes">Exclude Hidden Files</item>
                </items>
              </object>
            </property>
            <layout>
              <property name="column">3</property>
              <property name="row">6</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkDropDown" id="showload">
            <property name="model">
              <object class="GtkStringList" id="showload.strings">
                <items>
                  <item translatable="yes">Load Average:</item>
                  <item translatable="yes">for 1 minute</item>
                  <item translatable="yes">for 10 minutes</item>
                  <item translatable="yes">for 15 minutes</item>
                </items>
              </object>
            </property>
            <layout>
              <property name="column">3</property>
              <property name="row">7</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkDropDown" id="showmem">
            <property name="model">
              <object class="GtkStringList" id="showmem.strings">
                <items>
                  <item translatable="yes">Display Memory:</item>
                  <item translatable="yes">Used Memory [MB]</item>
                  <item translatable="yes">Free Memory [MB]</item>
                  <item translatable="yes">Used Memory [%]</item>
                  <item translatable="yes">Free Memory [%]</item>
                </items>
              </object>
            </property>
            <layout>
              <property name="column">3</property>
              <property name="row">8</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="showuptime">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Uptime</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">2</property>
              <property name="row">7</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="showtty">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Current TTY</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">2</property>
              <property name="row">8</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="showbatteryload">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Show Battery Load</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">1</property>
              <property name="row">9</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="toolbox.label.bsng">
            <property name="label" translatable="yes">BashStyle Stuff</property>
            <attributes>
              <attribute name="weight" value="bold"/>
            </attributes>
            <style>
              <class name="rotated_label"/>
            </style>
            <layout>
              <property name="column">0</property>
              <property name="row">6</property>
              <property name="row-span">5</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="toolbox.close">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Close</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">3</property>
              <property name="row">12</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkSeparator" id="toolbox.separator.2">
            <property name="margin-bottom">5</property>
            <property name="margin-top">5</property>
            <layout>
              <property name="column">0</property>
              <property name="column-span">4</property>
              <property name="row">11</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkDropDown" id="showspace">
            <property name="model">
              <object class="GtkStringList" id="showspace.strings">
                <items>
                  <item translatable="yes">Display Diskspace:</item>
                  <item translatable="yes">Used Space [MB]</item>
                  <item translatable="yes">Free Space [MB]</item>
                  <item translatable="yes">Used Space [%]</item>
                  <item translatable="yes">Free Space [%]</item>
                </items>
              </object>
            </property>
            <layout>
              <property name="column">3</property>
              <property name="row">9</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="showexit">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Show Exit Value</property>
            <property name="receives-default">1</property>
            <layout>
              <property name="column">2</property>
              <property name="row">9</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="showlastcmd">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Show Last Command</property>
            <property name="receives-default">1</property>
            <property name="width-request">175</property>
            <layout>
              <property name="column">1</property>
              <property name="row">10</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="showlastcmd_cut">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Show Last Command (cut)</property>
            <property name="receives-default">1</property>
            <property name="width-request">175</property>
            <layout>
              <property name="column">2</property>
              <property name="row">10</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="showuser">
            <property name="focusable">1</property>
            <property name="label" translatable="yes">Show User</property>
            <property name="receives-default">1</property>
            <property name="width-request">175</property>
            <layout>
              <property name="column">3</property>
              <property name="row">10</property>
            </layout>
          </object>
        </child>
      </object>
    </property>
    <property name="icon-name">bashstyle-ng-toolbox</property>
    <property name="title" translatable="yes">BashStyle-NG Toolbox</property>
  </object>
  <object class="GtkWindow" id="bashstyle">
    <property name="child">
      <object class="GtkBox" id="bashstyle.box">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox" id="bashstyle.buttonbox">
            <property name="can-focus">False</property>
            <property name="homogeneous">True</property>
            <property name="margin-bottom">2</property>
            <property name="margin-end">4</property>
            <property name="margin-start">4</property>
            <property name="margin-top">4</property>
            <property name="spacing">6</property>
            <property name="visible">True</property>
            <child>
              <object class="GtkButton" id="back">
                <property name="focusable">1</property>
                <property name="has-frame">false</property>
                <property name="receives-default">1</property>
                <child>
                  <object class="GtkBox" id="back.box">
                    <child>
                      <object class="GtkImage" id="back.image">
                        <property name="icon-name">go-previous</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="back.label">
                        <property name="label" translatable="yes">Back</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="main.label">
                <property name="ellipsize">start</property>
                <property name="label" translatable="yes">Choose a category:</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                </attributes>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="revert_user">
                <property name="icon-name">edit-undo</property>
                <property name="tooltip-text" translatable="yes">Revert to currently saved user configuration and reload</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="revert_factory">
                <property name="icon-name">edit-clear</property>
                <property name="tooltip-text" translatable="yes">Revert to factory (or vendor) configuration and reload</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkNotebook" id="notebook">
            <property name="margin-top">4</property>
            <property name="page">16</property>
            <property name="scrollable">1</property>
            <property name="show-border">0</property>
            <property name="show-tabs">False</property>
            <child>
              <object class="GtkNotebookPage">
                <property name="child">
                  <object class="GtkScrolledWindow" id="iconview.scrolledwindow">
                    <property name="child">
                      <object class="GtkGridView" id="iconview">
                        <property name="focusable">1</property>
                        <property name="margin-bottom">6</property>
                        <property name="margin-end">6</property>
                        <property name="margin-start">6</property>
                        <property name="margin-top">6</property>
                        <property name="max-columns">5</property>
                      </object>
                    </property>
                  </object>
                </property>
                <property name="tab">
                  <object class="GtkLabel" id="iconview.label">
                    <property name="label" translatable="yes">IconView</property>
                    <property name="visible">0</property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkNotebookPage">
                <property name="child">
                  <object class="GtkScrolledWindow" id="style.scrolledwindow">
                    <property name="child">
                      <object class="GtkViewport" id="style.viewport">
                        <property name="child">
                          <object class="GtkGrid" id="style.grid">
                            <property name="column-spacing">15</property>
                            <property name="halign">center</property>
                            <property name="margin-top">1</property>
                            <property name="row-spacing">3</property>
                            <property name="valign">center</property>
                            <child>
                              <object class="GtkLabel" id="style.label.basic1">
                                <property name="label" translatable="yes">Basic</property>
                                <attributes>
                                  <attribute name="weight" value="bold"/>
                                </attributes>
                                <style>
                                  <class name="rotated_label"/>
                                </style>
                                <layout>
                                  <property name="column">0</property>
                                  <property name="row">0</property>
                                  <property name="row-span">2</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkCheckButton" id="colored_prompts">
                                <property name="focusable">1</property>
                                <property name="label" translatable="yes">Colored Prompts</property>
                                <layout>
                                  <property name="column">2</property>
                                  <property name="row">0</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="style.label.colors">
                                <property name="label" translatable="yes">Colors</property>
                                <attributes>
                                  <attribute name="weight" value="bold"/>
                                </attributes>
                                <style>
                                  <class name="rotated_label"/>
                                </style>
                                <layout>
                                  <property name="column">0</property>
                                  <property name="row">3</property>
                                  <property name="row-span">17</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkCheckButton" id="ls_color">
                                <property name="focusable">1</property>
                                <property name="label" translatable="yes">Colored ls output</property>
                                <layout>
                                  <property name="column">2</property>
                                  <property name="row">21</property>
                                  <property name="row-span">2</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkSeparator" id="separator3">
                                <property name="margin-bottom">3</property>
                                <property name="margin-top">3</property>
                                <layout>
                                  <property name="column">0</property>
                                  <property name="column-span">3</property>
                                  <property name="row">2</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="style.label.separator">
                                <property name="label" translatable="yes">Separator</property>
                                <attributes>
                                  <attribute name="weight" value="bold"/>
                                </attributes>
                                <style>
                                  <class name="rotated_label"/>
                                </style>
                                <layout>
                                  <property name="column">0</property>
                                  <property name="row">30</property>
                                  <property name="row-span">5</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="style.label.style">
                                <property name="label" translatable="yes">Style</property>
                                <attributes>
                                  <attribute name="weight" value="bold"/>
                                </attributes>
                                <style>
                                  <class name="rotated_label"/>
                                </style>
                                <layout>
                                  <property name="column">0</property>
                                  <property name="row">20</property>
                                  <property name="row-span">9</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkBox" id="use_bashstyle_box">
                                <property name="spacing">6</property>
                                <property name="valign">center</property>
                                <child>
                                  <object class="GtkLabel" id="use_bashstyle_label">
                                    <property name="hexpand">1</property>
                                    <property name="label" translatable="yes">Enable BashStyle</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkSwitch" id="use_bashstyle">
                                    <property name="focusable">1</property>
                                  </object>
                                </child>
                                <layout>
                                  <property name="column">1</property>
                                  <property name="row">0</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkCheckButton" id="colorshell">
                                <property name="focusable">1</property>
                                <property name="label" translatable="yes">Randomly colored text</property>
                                <layout>
                                  <property name="column">1</property>
                                  <property name="row">3</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkDropDown" id="color_ps3">
                                <property name="model">
                                  <object class="GtkStringList" id="color_ps3.strings">
                                    <items>
                                      <item translatable="yes">Black</item>
                                      <item translatable="yes">Red</item>
                                      <item translatable="yes">Green</item>
                                      <item translatable="yes">Yellow</item>
                                      <item translatable="yes">Blue</item>
                                      <item translatable="yes">Magenta</item>
                                      <item translatable="yes">Cyan</item>
                                      <item translatable="yes">Grey</item>
                                      <item translatable="yes">White</item>
                                      <item translatable="yes">Coldblue</item>
                                      <item translatable="yes">Smoothblue</item>
                                      <item translatable="yes">Iceblue</item>
                                      <item translatable="yes">Turqoise</item>
                                      <item translatable="yes">Smoothgreen</item>
                                      <item translatable="yes">Winered</item>
                                      <item translatable="yes">Brown</item>
                                      <item translatable="yes">Silver</item>
                                      <item translatable="yes">Ocher</item>
                                      <item translatable="yes">Orange</item>
                                      <item translatable="yes">Purple</item>
                                      <item translatable="yes">Pink</item>
                                      <item translatable="yes">Cream</item>
                                    </items>
                                  </object>
                                </property>
                                <layout>
                                  <property name="column">1</property>
                                  <property name="row">17</property>
                                </layout>
                              </object>
                            </child>
                            <child>
                              <object class="GtkSeparator" id="separator4">
                                <property name="margin-bottom">3</property>
                                <property name="margin-top">3</property>
                                <layout>
